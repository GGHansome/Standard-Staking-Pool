# 拷贝为 .env.local 后填充：
#   cp .env.example .env.local
#
# 本地 anvil 调试流程：
#   1. 终端 A: anvil
#   2. 终端 B:
#        cd contract
#        forge script script/DeployLocal.s.sol \
#          --rpc-url http://127.0.0.1:8545 \
#          --broadcast \
#          --private-key "0x0000"
#   3. 把脚本结尾打印的 StakingPool 地址填到下方 VITE_STAKING_POOL_ADDRESS
VITE_STAKING_POOL_ADDRESS=
VITE_CHAIN_ID=31337
VITE_CHAIN_NAME=Anvil
VITE_RPC_URL=http://127.0.0.1:8545
# 本地 mock 代币可填固定价格用于展示和 APR 估算；留空则不使用本地价格。
VITE_STAKING_TOKEN_USD_PRICE=
VITE_REWARD_TOKEN_USD_PRICE=
# 没有配置固定价格时，才会按 CoinGecko ID 请求真实价格；本地 mock 代币留空即可。
VITE_STAKING_TOKEN_COINGECKO_ID=
VITE_REWARD_TOKEN_COINGECKO_ID=
